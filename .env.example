# Supabase (use pooler URL — no local postgres)
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@REGION.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxx
SUPABASE_SECRET_KEY=sb_secret_xxxxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxx

# Auth (browser-safe — can use sb_publishable or legacy anon)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx

# Email (Gmail)
EMAIL_FROM=consult@yourdomain.com

# Google Workspace (OAuth 2.0 — each doctor connects own Gmail)
GOOGLE_OAUTH_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/google/callback

# Sentry
SENTRY_DSN=https://your-dsn@sentry.io/your-project
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# Admin
SUPER_ADMIN_EMAIL=admin@yourdomain.com
