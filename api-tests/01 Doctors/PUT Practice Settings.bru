meta {
  name: PUT Practice Settings
  method: PUT
  type: http
  url: {{base_url}}/api/doctors/me/practice-settings
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
}

body:json {
  {
    "slotLength": 30,
    "bufferTime": 10,
    "consultationFee": 50,
    "videoFee": 50,
    "inPersonFee": 50,
    "cancellationCutoff": 24
  }
}
