meta {
  name: POST Create Feedback
  method: POST
  type: http
  url: {{base_url}}/api/feedback
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
}

body:json {
  {
    "bookingId": "{{booking_id}}",
    "rating": 5,
    "comment": "Excellent consultation, very thorough."
  }
}
