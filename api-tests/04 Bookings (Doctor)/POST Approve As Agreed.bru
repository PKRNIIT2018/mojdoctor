meta {
  name: POST Approve As Agreed
  method: POST
  type: http
  url: {{base_url}}/api/bookings/approve-as-agreed
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
}

body:json {
  {
    "bookingId": "{{booking_id}}",
    "internalNote": "Existing patient, no payment needed"
  }
}
