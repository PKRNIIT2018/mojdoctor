meta {
  name: POST Send Confirmation
  method: POST
  type: http
  url: {{base_url}}/api/notifications/send-confirmation/{{booking_id}}
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
}

body:json {
  {
    "patientEmail": "{{patient_email}}",
    "patientName": "{{patient_name}}"
  }
}
