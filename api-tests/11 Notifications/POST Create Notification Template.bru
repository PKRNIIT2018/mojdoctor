meta {
  name: POST Create Notification Template
  method: POST
  type: http
  url: {{base_url}}/api/notifications/templates
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
}

body:json {
  {
    "type": "reminder",
    "subject": "Appointment Reminder",
    "body": "Dear patient, you have an appointment tomorrow at {{time}}.",
    "channel": "email"
  }
}
