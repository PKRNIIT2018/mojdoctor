meta {
  name: POST Send Notification
  method: POST
  type: http
  url: {{base_url}}/api/notifications/send
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
}

body:json {
  {
    "templateId": "{{notification_template_id}}",
    "to": "{{patient_email}}",
    "variables": { "name": "John" }
  }
}
