meta {
  name: POST Create Rule
  method: POST
  type: http
  url: {{base_url}}/api/slots/rules?doctorId={{doctor_id}}
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
}

body:json {
  {
    "dayOfWeek": 1,
    "startTime": "09:00",
    "endTime": "17:00",
    "mode": "video",
    "isActive": true
  }
}
