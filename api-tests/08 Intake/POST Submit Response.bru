meta {
  name: POST Submit Response
  method: POST
  type: http
  url: {{base_url}}/api/intake/responses
}

headers {
  Authorization: Bearer {{auth_token}}
  Content-Type: application/json
}

body:json {
  {
    "bookingId": "{{booking_id}}",
    "responses": {
      "Full Name": "John Doe",
      "Date of Birth": "1990-01-15",
      "Allergies": "Penicillin"
    }
  }
}
